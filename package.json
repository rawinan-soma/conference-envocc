{
	"name": "conference-envocc",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --check .",
		"format:write": "prettier --write .",
		"test:unit": "vitest --project server",
		"test": "bun run test:unit -- --run",
		"test:integration": "vitest run --project integration",
		"test:ci": "bun run lint && bun run check && bun run test && bun run test:integration && bun run test:e2e",
		"test:e2e": "playwright test",
		"test:e2e:install": "playwright install",
		"db:start": "docker compose up",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"worker": "bun run src/worker.ts"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.18.2",
		"@playwright/test": "^1.60.0",
		"@sveltejs/kit": "^2.65.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@testcontainers/postgresql": "^12.0.1",
		"@types/node": "^24",
		"@types/nodemailer": "^8.0.0",
		"@types/pg": "^8.20.0",
		"@types/pino": "^7.0.5",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"testcontainers": "^12.0.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"better-auth": "^1.6.16",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"nodemailer": "^8.0.10",
		"pg": "^8.21.0",
		"pg-boss": "^12.18.2",
		"pino": "^10.3.1",
		"tailwind-merge": "^3.6.0",
		"uuidv7": "^1.2.1",
		"valibot": "^1.4.1"
	},
	"trustedDependencies": [
		"protobufjs"
	]
}
