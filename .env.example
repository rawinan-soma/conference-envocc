# Database (used by all services)
DATABASE_URL=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=conference_envocc

# Web server (docker)
HOST=0.0.0.0
PORT=3000

# Optional: unix socket for nginx (if using socket mode)
# SOCKET=/run/web.sock

# SMTP (Mailpit in dev: docker compose up mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@conference-envocc.local
SMTP_DISPLAY_NAME=Conference EnvOcc
# Optional — leave blank for Mailpit (no auth required in dev)
SMTP_USER=
SMTP_PASS=
# Optional — set to "true" for TLS; defaults to false for Mailpit
SMTP_SECURE=false

# Mailpit (dev only) — inbox URL for log messages
MAILPIT_URL=http://localhost:8025

# Test / CI (used by integration tests)
# In CI, DATABASE_URL is set via GitHub Actions secrets (TEST_DB_PASSWORD).
# When running integration tests locally without a running Postgres instance,
# Testcontainers will automatically start a temporary postgres:17 container
# and set DATABASE_URL for the test process.
# Ensure Docker is running locally for Testcontainers to work.

# Auth — Better Auth + Authentik OIDC (Story 2.1)
# AUTH_SECRET: minimum 32 characters; generate with: openssl rand -base64 32
# AUTHENTIK_ISSUER: base URL of your Authentik instance, e.g. https://auth.example.com/application/o/conference/
# IMPORTANT: Do NOT commit real values. Use GH Secrets/Vars in CI.
AUTH_SECRET=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_ISSUER=

# DEV ONLY — never set in production. Enables /auth/dev-bypass without Authentik.
# AUTH_DEV_BYPASS=

# Room photo upload (Story 3.2)
# UPLOAD_DIR: path to the on-prem volume mount where room photos are stored.
# Must be set at runtime. In Docker, this is mounted as a named volume (see compose.yaml).
# Dev example: UPLOAD_DIR=./uploads (create the directory manually if testing locally)
UPLOAD_DIR=./uploads
# PHOTO_MAX_BYTES: maximum upload size in bytes. Defaults to 10485760 (10MB) if not set.
# PHOTO_MAX_BYTES=10485760
