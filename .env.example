# Database (used by all services)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/conference_envocc
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=conference_envocc

# Web server (docker)
HOST=0.0.0.0
PORT=3000

# Optional: unix socket for nginx (if using socket mode)
# SOCKET=/run/web.sock

# SMTP (Mailpit in dev: docker compose up mailpit)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@conference-envocc.local
SMTP_DISPLAY_NAME=Conference EnvOcc
# Optional — leave blank for Mailpit (no auth required in dev)
SMTP_USER=
SMTP_PASS=
# Optional — set to "true" for TLS; defaults to false for Mailpit
SMTP_SECURE=false

# Mailpit (dev only) — inbox URL for log messages
MAILPIT_URL=http://localhost:8025

# TODO (story 2.1): Auth
# AUTH_SECRET=change-me-32-chars-min
# AUTHENTIK_CLIENT_ID=
# AUTHENTIK_CLIENT_SECRET=
# AUTHENTIK_ISSUER=
